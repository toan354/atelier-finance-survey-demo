# Atelier Finance AI assistant provider configuration.
# Default safe mode: does not call any LLM and does not create API cost.
AI_ASSISTANT_PROVIDER=none

# Phase 29B local database configuration.
# Dev default uses SQLite for low-friction setup. Production target is PostgreSQL.
# Do not commit .env.local or real database credentials.
DATABASE_URL="file:./dev.db"

# Optional provider modes:
# - none: safe default, no LLM call.
# - mock: dev/test only; uses AI_ASSISTANT_MOCK_ANSWER and still runs guardrail validation.
# - openai: local real-provider testing only; requires OPENAI_API_KEY.
AI_ASSISTANT_MOCK_ANSWER=

# OpenAI local verification.
# Do not commit .env.local. Do not put real API keys in source code, docs, issues,
# commit messages, or public screenshots.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
