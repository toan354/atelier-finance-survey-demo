    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "22.15.29",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.21",
    "eslint": "9.28.0",
    "eslint-config-next": "^16.2.7",
    "postcss": "8.5.4",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.17",
